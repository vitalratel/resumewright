{
  "name": "@resumewright/extension",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "ResumeWright browser extension",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build:gleam": "cd ../app_gleam && mise exec -- gleam run -m lustre/dev build app_gleam",
    "build:background": "cd ../app_gleam && mise exec -- gleam build --target javascript && node scripts/build-background.mjs",
    "build": "pnpm build:gleam && pnpm build:background && pnpm validate:wasm-types && wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:wasm": "cd ../../ && cargo build --release --target wasm32-unknown-unknown && wasm-pack build --release --target web packages/rust-core/wasm-bridge",
    "validate:wasm-types": "node scripts/validate-wasm-types.mjs",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "preview": "wxt preview",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:e2e",
    "test:all": "pnpm test:e2e && pnpm test:a11y",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:file": "pnpm exec playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:performance": "playwright test tests/performance",
    "test:extension": "playwright test tests/e2e",
    "test:a11y": "playwright test tests/accessibility",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write"
  },
  "dependencies": {},
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.2.3",
    "autoprefixer": "^10.4.24",
    "axe-core": "^4.11.1",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-wasm": "^3.3.0"
  }
}
