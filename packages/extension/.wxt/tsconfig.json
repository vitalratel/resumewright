{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/background": ["../src/background"],
      "@/background/*": ["../src/background/*"],
      "@/popup": ["../src/popup"],
      "@/popup/*": ["../src/popup/*"],
      "@/shared": ["../src/shared"],
      "@/shared/*": ["../src/shared/*"],
      "@pkg": ["../../rust-core/wasm-bridge/pkg"],
      "@pkg/*": ["../../rust-core/wasm-bridge/pkg/*"],
      "@": [".."],
      "@/*": ["../*"],
      "~": [".."],
      "~/*": ["../*"],
      "@@": [".."],
      "@@/*": ["../*"],
      "~~": [".."],
      "~~/*": ["../*"]
    }
  },
  "include": [
    "../**/*",
    "./wxt.d.ts"
  ],
  "exclude": ["../.output"]
}